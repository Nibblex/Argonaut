  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <name>Argonaut</name>
  <summary>Translate documents offline</summary>
  <summary xml:lang="es">Traduce documentos sin conexión</summary>

  <description>
    <p>
      Argonaut is a minimalist document translator. Translation runs
      entirely on your computer using Argos Translate; your documents
      never leave your machine.
    </p>
    <p>Features:</p>
    <ul>
      <li>Batch translation with automatic language detection per file</li>
      <li>PDF translation that preserves the layout, with real progress and cancellation</li>
      <li>Supports .txt, .docx, .odt, .odp, .pptx, .epub, .html, .srt and .pdf</li>
      <li>Interface in English, Spanish, French, German, Italian and Portuguese</li>
    </ul>
  </description>

  <developer id="io.github.nibblex">
    <name>Sergio Rodríguez</name>
  </developer>

  <launchable type="desktop-id">io.github.nibblex.Argonaut.desktop</launchable>

  <url type="homepage">https://github.com/Nibblex/Argonaut</url>
  <url type="bugtracker">https://github.com/Nibblex/Argonaut/issues</url>
  <url type="vcs-browser">https://github.com/Nibblex/Argonaut</url>

